{
  "name": "tellur-vscode",
  "displayName": "Tellur — AI Code Provenance",
  "description": "See who changed what: AI or human. Line-level attribution, session replay, and PR risk reports.",
  "version": "0.1.0",
  "publisher": "tellur",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sydneyvb-nl/tellur"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Tellur runs the configured CLI and writes provenance data in the workspace, so the workspace must be trusted first."
    }
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "ai",
    "attribution",
    "provenance",
    "code review",
    "git"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tellur.init",
        "title": "Tellur: Initialize"
      },
      {
        "command": "tellur.explain",
        "title": "Tellur: Explain Current Line"
      },
      {
        "command": "tellur.blame",
        "title": "Tellur: Show File Attribution"
      },
      {
        "command": "tellur.prReport",
        "title": "Tellur: Generate PR Report"
      },
      {
        "command": "tellur.sessions",
        "title": "Tellur: Show Sessions"
      },
      {
        "command": "tellur.policyCheck",
        "title": "Tellur: Check Policy"
      },
      {
        "command": "tellur.startWatch",
        "title": "Tellur: Start Watching"
      },
      {
        "command": "tellur.stopWatch",
        "title": "Tellur: Stop Watching"
      },
      {
        "command": "tellur.selectVSCodeModel",
        "title": "Tellur: Select VS Code AI Model"
      },
      {
        "command": "tellur.diagnoseVSCodeModels",
        "title": "Tellur: Diagnose VS Code AI Models"
      },
      {
        "command": "tellur.recordPrompt",
        "title": "Tellur: Record AI Prompt"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tellur",
          "title": "Tellur",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "tellur": [
        {
          "id": "tellur.sessions",
          "name": "Sessions"
        },
        {
          "id": "tellur.attributions",
          "name": "Attributions"
        }
      ]
    },
    "configuration": {
      "title": "Tellur",
      "properties": {
        "tellur.tellurPath": {
          "type": "string",
          "default": "tellur",
          "description": "Path to the tellur CLI binary"
        },
        "tellur.showInlineDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show inline attribution decorations in the editor"
        },
        "tellur.aiColor": {
          "type": "string",
          "default": "rgba(138, 43, 226, 0.15)",
          "description": "Background color for AI-generated lines"
        },
        "tellur.humanColor": {
          "type": "string",
          "default": "rgba(34, 139, 34, 0.15)",
          "description": "Background color for human-written lines"
        },
        "tellur.autoWatch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start watching when opening a workspace"
        },
        "tellur.autoInit": {
          "type": "boolean",
          "default": true,
          "description": "Automatically initialize Tellur storage in Git workspaces"
        },
        "tellur.captureOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Capture saved file changes through Tellur hook ingestion"
        },
        "tellur.vscodeAgentId": {
          "type": "string",
          "default": "",
          "description": "Optional agent/tool identifier override. Empty automatically selects vscode, cursor, or windsurf from the host editor."
        },
        "tellur.vscodeAgentName": {
          "type": "string",
          "default": "",
          "description": "Optional human-readable agent/tool name override. Empty uses the detected host editor name."
        },
        "tellur.vscodeModelId": {
          "type": "string",
          "default": "",
          "description": "Optional VS Code language model identifier to attach to watch sessions, for example openai:gpt-5"
        },
        "tellur.vscodePromptSessionId": {
          "type": "string",
          "default": "",
          "description": "Optional session ID used when recording prompt hashes. Empty uses the detected or configured editor source."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test:unit": "npm run compile && node ./out/test/unit.js",
    "test:extension": "npm run compile && node ./out/test/runTest.js",
    "test": "npm run test:unit && npm run test:extension",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "cheerio": "1.0.0"
  }
}
