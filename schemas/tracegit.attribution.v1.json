{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tracegit.dev/schemas/tracegit.attribution.v1.json",
  "title": "TraceGit File Attribution",
  "description": "Maps code ranges to AI origin information for a specific file",
  "type": "object",
  "required": ["schema", "filePath", "gitBlobSha", "ranges", "updatedAt"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "tracegit.attribution.v1"
    },
    "filePath": {
      "type": "string"
    },
    "gitBlobSha": {
      "type": "string"
    },
    "ranges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/attributionRange"
      }
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "attributionRange": {
      "type": "object",
      "required": ["rangeId", "startLine", "endLine", "origin", "evidenceStrength", "confidence", "state", "sessionId", "eventIds", "agentId", "policyTags", "riskTags", "testsRun", "testsPassed"],
      "properties": {
        "rangeId": { "type": "string" },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 },
        "origin": { "type": "string", "enum": ["human", "ai", "mixed", "unknown"] },
        "evidenceStrength": { "type": "string", "enum": ["recorded", "imported", "inferred", "claimed", "unknown"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "state": { "type": "string", "enum": ["exact", "moved", "modified", "split", "merged", "uncertain", "lost"] },
        "sessionId": { "type": "string" },
        "eventIds": { "type": "array", "items": { "type": "string" } },
        "agentId": { "type": "string" },
        "modelId": { "type": "string" },
        "promptHash": { "type": "string" },
        "contextSetId": { "type": "string" },
        "policyTags": { "type": "array", "items": { "type": "string" } },
        "riskTags": { "type": "array", "items": { "type": "string" } },
        "riskLevel": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "testsRun": { "type": "array", "items": { "type": "string" } },
        "testsPassed": { "type": "boolean" },
        "reviewer": { "type": "string" },
        "reviewedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
