{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tellur.dev/schemas/tellur.event.v1.json",
  "title": "Tellur Event",
  "description": "A timestamped action within an AI development session",
  "type": "object",
  "required": ["schema", "id", "session_id", "timestamp", "type", "actor", "payload"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "tellur.event.v1"
    },
    "id": {
      "type": "string",
      "description": "Unique event identifier"
    },
    "session_id": {
      "type": "string",
      "description": "Parent session identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": [
        "session.start", "session.end",
        "prompt.submitted", "prompt.context_added",
        "file.read", "file.write", "file.patch", "file.delete",
        "command.pre_execute", "command.post_execute",
        "command.exec", "code.search", "user.prompt",
        "tool.pre_call", "tool.post_call",
        "mcp.pre_call", "mcp.post_call",
        "test.run", "test.result",
        "git.diff", "git.commit", "git.branch", "git.merge", "git.rebase",
        "policy.violation", "policy.override",
        "review.approval",
        "export.created",
        "custom"
      ]
    },
    "actor": {
      "type": "string",
      "enum": ["human", "agent", "system", "unknown"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "redaction": {
      "$ref": "#/definitions/redactionInfo"
    },
    "prev_hash": {
      "type": "string",
      "description": "SHA-256 hash of the previous event (chain)"
    },
    "event_hash": {
      "type": "string",
      "description": "SHA-256 hash of this event"
    }
  },
  "definitions": {
    "redactionInfo": {
      "type": "object",
      "required": ["applied", "mode"],
      "properties": {
        "applied": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["none", "automatic", "strict", "hash-only", "custom"]
        },
        "rules_applied": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
